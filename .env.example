# Database URL (PostgreSQL + pgvector)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/velmo

# Redis URL (Rate limiting, session cache)
REDIS_URL=redis://localhost:6379/0

# LLM Principal / Judge Agent (Azure Chat OpenAI - Kimi 2.6)
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://eagwu-0283-resource.services.ai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=Kimi-K2.6
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# Latency tuning (see docs/OPTIMISATIONS_LATENCE.md)
# Point the classifier at a lighter/faster deployment (defaults to the main one).
# Must be a model actually DEPLOYED in your AZURE_OPENAI_ENDPOINT resource.
# Tested: gpt-5.4-mini -> ~3x faster than model-router (langchain>=1.3.3 handles
# its GPT-5 param constraints automatically). Leave empty to fall back.
CLASSIFIER_DEPLOYMENT_NAME=gpt-5.4-mini
# Classifier emits a single category word -> keep this small.
# Note: some deployments (gpt-4.1-mini, o*/codex) require a minimum of 16.
CLASSIFIER_MAX_TOKENS=16
# Cap worst-case response generation length
RESPONSE_MAX_TOKENS=512

# OpenAI API (for embeddings text-embedding-3-small/large)
# If you don't have a separate OpenAI key, Azure OpenAI endpoint can also be used if configured.
OPENAI_API_KEY=

# LangSmith (Observability - Chantier 3)
# Set LANGSMITH_TRACING=true and provide an API key to enable tracing.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=velmo-2.0
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
